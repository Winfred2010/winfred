# --- Input Validation ---
# Ensuring name input contains at least 3 letters and no digits
while True:
    user_name = input("Enter your name: ").strip()
    if not user_name.isdigit() and len(user_name) >= 3:
        print("Thank you, name recorded.")
        break
    print("Invalid input. Name must be 3+ characters and text-only.")


# --- Collection Searching ---
# Comparing user choice against a list of preferences
fav_fruits = input("Enter your favorite fruits (separated by space): ").lower().split()
choice = input("Check a specific fruit: ").lower()

if choice in fav_fruits:
    print("You chose one of your favorite fruits! Enjoy!")
else:
    print("You chose a new fruit. I hope you enjoy it!")


# --- Loop-driven Calculations ---
# Pizza cost calculator: $10 base + $2.50 per topping
toppings_list = []
while True:
    selection = input("Add a topping (or type 'quit'): ").strip().lower()
    if selection == 'quit':
        break
    print(f"Adding {selection} to your pizza.")
    toppings_list.append(selection)

total_price = 10 + (len(toppings_list) * 2.5)
print(f"Toppings: {toppings_list} | Total Price: ${total_price:.2f}")


# --- Conditional Logic (Ticketing) ---
# Age-based pricing for Cinemax
family_ages = input("Enter family ages (space separated): ").split()
bill = 0

for age_val in family_ages:
    age = int(age_val)
    if 3 <= age <= 12:
        bill += 10
    elif age > 12:
        bill += 15

print(f"Total family ticket cost: ${bill}")


# --- Filtered Lists (Restricted Movie) ---
# Filtering a group based on age requirements (16-21)
group = ["Alice", "Bob", "Charlie", "David"]
allowed = []

for person in group:
    age = int(input(f"Enter age for {person}: "))
    if 16 <= age <= 21:
        allowed.append(person)

print(f"Authorized attendees: {allowed}")