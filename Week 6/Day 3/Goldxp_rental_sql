-- EXERCISE 1: RENTALS & ACTORS

-- 1 & 2. Outstanding rentals and the customers who have them
SELECT 
    c.first_name, 
    c.last_name, 
    f.title, 
    r.rental_date
FROM rental r
JOIN customer c ON r.customer_id = c.customer_id
JOIN inventory i ON r.inventory_id = i.inventory_id
JOIN film f ON i.film_id = f.film_id
WHERE r.return_date IS NULL
ORDER BY c.last_name;

-- 3. Action films with Joe Swank (Using existing views if available, else standard join)
SELECT f.title
FROM film f
JOIN film_category fc ON f.film_id = fc.film_id
JOIN category cat ON fc.category_id = cat.category_id
JOIN film_actor fa ON f.film_id = fa.film_id
JOIN actor a ON fa.actor_id = a.actor_id
WHERE a.first_name = 'Joe' 
  AND a.last_name = 'Swank' 
  AND cat.name = 'Action';

-- EXERCISE 2: ZOMBIE PLAGUE PREP

-- 1. Store locations (City & Country)
SELECT s.store_id, ci.city, co.country
FROM store s
JOIN address a ON s.address_id = a.address_id
JOIN city ci ON a.city_id = ci.city_id
JOIN country co ON ci.country_id = co.country_id;

-- 2 & 3. Total viewing hours per store (Excluding unreturned/outstanding items)
-- Note: Logic assumes inventory currently "out" shouldn't be counted as available for shelters
SELECT 
    i.store_id, 
    SUM(f.length) / 60 AS total_hours
FROM inventory i
JOIN film f ON i.film_id = f.film_id
LEFT JOIN rental r ON i.inventory_id = r.inventory_id AND r.return_date IS NULL
WHERE r.rental_id IS NULL
GROUP BY i.store_id;

-- 4. Customers in store cities
SELECT c.first_name, c.last_name, ci.city
FROM customer c
JOIN address a ON c.address_id = a.address_id
JOIN city ci ON a.city_id = ci.city_id
WHERE ci.city IN (
    SELECT ci2.city 
    FROM store s 
    JOIN address a2 ON s.address_id = a2.address_id 
    JOIN city ci2 ON a2.city_id = ci2.city_id
);

-- 5. Customers in store countries
SELECT c.first_name, c.last_name, co.country
FROM customer c
JOIN address a ON c.address_id = a.address_id
JOIN city ci ON a.city_id = ci.city_id
JOIN country co ON ci.country_id = co.country_id
WHERE co.country IN (
    SELECT co2.country 
    FROM store s 
    JOIN address a2 ON s.address_id = a2.address_id 
    JOIN city ci2 ON a2.city_id = ci2.city_id
    JOIN country co2 ON ci2.country_id = co2.country_id
);

-- 6 & 7. Safe List (No Horror/Scary words) with time conversions
SELECT 
    SUM(length) AS total_minutes,
    ROUND(SUM(length)::numeric / 60, 2) AS total_hours,
    ROUND(SUM(length)::numeric / 1440, 2) AS total_days
FROM film f
WHERE f.film_id NOT IN (
    SELECT fc.film_id 
    FROM film_category fc 
    JOIN category cat ON fc.category_id = cat.category_id 
    WHERE cat.name = 'Horror'
)
AND f.title NOT ILIKE ANY (ARRAY['%beast%', '%monster%', '%ghost%', '%dead%', '%zombie%', '%undead%'])
AND f.description NOT ILIKE ANY (ARRAY['%beast%', '%monster%', '%ghost%', '%dead%', '%zombie%', '%undead%']);
